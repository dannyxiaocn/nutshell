{
  "name": "task_update",
  "description": "Update fields on an existing task card. Only the fields you pass will change.",
  "input_schema": {
    "type": "object",
    "properties": {
      "name": {
        "type": "string",
        "description": "Name of the task card to update."
      },
      "description": {
        "type": "string",
        "description": "New description for the task."
      },
      "interval": {
        "type": ["number", "null"],
        "description": "New recurring interval in seconds. Pass null to convert to a one-shot task."
      },
      "start_at": {
        "type": ["number", "null"],
        "description": "New earliest fire time (unix epoch seconds)."
      },
      "end_at": {
        "type": ["number", "null"],
        "description": "New auto-expire time (unix epoch seconds)."
      },
      "progress": {
        "type": "string",
        "description": "Updated progress notes."
      },
      "comments": {
        "type": "string",
        "description": "Updated comments/notes on the task."
      }
    },
    "required": ["name"]
  }
}
